# openGauss connection for the `gsql` client used by run_opengauss.py.
# gsql reads these from the environment; export them (or source this file)
# before running, and/or set JOB5_GSQL to the gsql binary if not on PATH.
PGHOST=127.0.0.1
PGPORT=15432
PGDATABASE=postgres
PGUSER=userroot
PGPASSWORD=openGauss@123
